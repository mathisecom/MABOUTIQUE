{% liquid
  assign s = section.settings
%}

<section id="hero-{{ section.id }}" class="custom-hero-banner">
  <div class="custom-hero-banner__media">
    {% if s.image_desktop != blank %}
      <img
        class="custom-hero-banner__image custom-hero-banner__image--desktop"
        src="{{ s.image_desktop | image_url: width: 2600 }}"
        alt="{{ s.image_alt | escape }}"
        loading="eager"
      >
    {% endif %}

    {% if s.image_mobile != blank %}
      <img
        class="custom-hero-banner__image custom-hero-banner__image--mobile"
        src="{{ s.image_mobile | image_url: width: 1000 }}"
        alt="{{ s.image_alt | escape }}"
        loading="eager"
      >
    {% elsif s.image_desktop != blank %}
      <img
        class="custom-hero-banner__image custom-hero-banner__image--mobile"
        src="{{ s.image_desktop | image_url: width: 1000 }}"
        alt="{{ s.image_alt | escape }}"
        loading="eager"
      >
    {% endif %}
  </div>

  <div class="custom-hero-banner__overlay"></div>

  <div class="custom-hero-banner__content">
    <div class="custom-hero-banner__box">
      {% if s.rating_text != blank %}
        <div class="custom-hero-banner__rating">
          <span class="custom-hero-banner__stars">★★★★★</span>
          <span>{{ s.rating_text }}</span>
        </div>
      {% endif %}

      {% if s.title != blank %}
        <h1 class="custom-hero-banner__title">
          {{ s.title }}
        </h1>
      {% endif %}

      {% if s.text != blank %}
        <div class="custom-hero-banner__text">
          {{ s.text }}
        </div>
      {% endif %}

      {% if s.button_label != blank %}
        <a href="{{ s.button_link }}" class="custom-hero-banner__button">
          {{ s.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #hero-{{ section.id }} {
    position: relative;
    min-height: {{ s.height_desktop }}px;
    overflow: hidden;
    background: {{ s.background_color }};
    color: {{ s.text_color }};
  }

  #hero-{{ section.id }} .custom-hero-banner__media {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  #hero-{{ section.id }} .custom-hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #hero-{{ section.id }} .custom-hero-banner__image--desktop {
    object-position: {{ s.desktop_image_position }};
  }

  #hero-{{ section.id }} .custom-hero-banner__image--mobile {
    display: none;
  }

  #hero-{{ section.id }} .custom-hero-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: {{ s.overlay_color }};
    opacity: {{ s.overlay_opacity | divided_by: 100.0 }};
  }

  #hero-{{ section.id }} .custom-hero-banner__content {
    position: relative;
    z-index: 3;
    min-height: {{ s.height_desktop }}px;
    display: flex;
    padding: {{ s.padding_top_desktop }}px {{ s.padding_horizontal_desktop }}px {{ s.padding_bottom_desktop }}px;
    box-sizing: border-box;

    {% case s.content_horizontal_desktop %}
      {% when 'left' %}
        justify-content: flex-start;
      {% when 'center' %}
        justify-content: center;
      {% when 'right' %}
        justify-content: flex-end;
    {% endcase %}

    {% case s.content_vertical_desktop %}
      {% when 'top' %}
        align-items: flex-start;
      {% when 'middle' %}
        align-items: center;
      {% when 'bottom' %}
        align-items: flex-end;
    {% endcase %}
  }

  #hero-{{ section.id }} .custom-hero-banner__box {
    max-width: {{ s.content_width }}px;
    text-align: {{ s.text_align_desktop }};
  }

  #hero-{{ section.id }} .custom-hero-banner__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: {% if s.text_align_desktop == 'center' %}center{% elsif s.text_align_desktop == 'right' %}flex-end{% else %}flex-start{% endif %};
    font-size: {{ s.rating_size_desktop }}px;
    font-weight: 700;
    margin-bottom: {{ s.rating_margin_bottom }}px;
    color: {{ s.rating_color }};
  }

  #hero-{{ section.id }} .custom-hero-banner__stars {
    color: {{ s.stars_color }};
    letter-spacing: 1px;
  }

  #hero-{{ section.id }} .custom-hero-banner__title {
    margin: 0 0 {{ s.title_margin_bottom }}px;
    font-size: {{ s.title_size_desktop }}px;
    line-height: 1.05;
    font-weight: {{ s.title_weight }};
    color: {{ s.text_color }};
  }

  #hero-{{ section.id }} .custom-hero-banner__text {
    font-size: {{ s.text_size_desktop }}px;
    line-height: 1.45;
    font-weight: {{ s.text_weight }};
    color: {{ s.text_color }};
    margin-bottom: {{ s.text_margin_bottom }}px;
  }

  #hero-{{ section.id }} .custom-hero-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ s.button_padding_vertical }}px {{ s.button_padding_horizontal }}px;
    border-radius: {{ s.button_radius }}px;
    background: {{ s.button_background }};
    color: {{ s.button_text_color }};
    font-size: {{ s.button_text_size }}px;
    font-weight: {{ s.button_text_weight }};
    text-decoration: none;
    transition: 0.25s ease;
  }

  #hero-{{ section.id }} .custom-hero-banner__button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    #hero-{{ section.id }} {
      min-height: {{ s.height_mobile }}px;
    }

    #hero-{{ section.id }} .custom-hero-banner__image--desktop {
      display: none;
    }

    #hero-{{ section.id }} .custom-hero-banner__image--mobile {
      display: block;
      object-position: {{ s.mobile_image_position }};
    }

    #hero-{{ section.id }} .custom-hero-banner__content {
      min-height: {{ s.height_mobile }}px;
      padding: {{ s.padding_top_mobile }}px {{ s.padding_horizontal_mobile }}px {{ s.padding_bottom_mobile }}px;

      {% case s.content_horizontal_mobile %}
        {% when 'left' %}
          justify-content: flex-start;
        {% when 'center' %}
          justify-content: center;
        {% when 'right' %}
          justify-content: flex-end;
      {% endcase %}

      {% case s.content_vertical_mobile %}
        {% when 'top' %}
          align-items: flex-start;
        {% when 'middle' %}
          align-items: center;
        {% when 'bottom' %}
          align-items: flex-end;
      {% endcase %}
    }

    #hero-{{ section.id }} .custom-hero-banner__box {
      max-width: {{ s.content_width_mobile }}px;
      text-align: {{ s.text_align_mobile }};
    }

    #hero-{{ section.id }} .custom-hero-banner__rating {
      justify-content: {% if s.text_align_mobile == 'center' %}center{% elsif s.text_align_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
      font-size: {{ s.rating_size_mobile }}px;
    }

    #hero-{{ section.id }} .custom-hero-banner__title {
      font-size: {{ s.title_size_mobile }}px;
    }

    #hero-{{ section.id }} .custom-hero-banner__text {
      font-size: {{ s.text_size_mobile }}px;
    }
  }
</style>

{% schema %}
